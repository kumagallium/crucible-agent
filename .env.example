# === LLM ===
LITELLM_API_BASE=http://litellm:4000
LLM_MODEL=sakura-model-name
SAKURA_AI_API_KEY=your-key
SAKURA_AI_API_BASE=https://your-sakura-endpoint

# === Crucible ===
CRUCIBLE_API_URL=http://crucible-api:8080
CRUCIBLE_API_KEY=your-crucible-api-key

# === Database ===
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/crucible_agent

# === Agent ===
AGENT_PORT=8090
CHAT_UI_ENABLED=true
LOG_LEVEL=info
