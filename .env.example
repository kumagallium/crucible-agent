# === LLM ===
LITELLM_API_BASE=http://litellm:4000
LLM_MODEL=sakura

# さくら AI Engine
SAKURA_AI_API_KEY=your-key
SAKURA_AI_API_BASE=https://your-sakura-endpoint

# --- 追加プロバイダー（litellm_config.yaml でモデルを有効化した場合に設定） ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# === Crucible ===
CRUCIBLE_API_URL=http://crucible-api:8080
CRUCIBLE_API_KEY=your-crucible-api-key

# === Database ===
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/crucible_agent

# === Agent ===
AGENT_PORT=8090
CHAT_UI_ENABLED=true
LOG_LEVEL=info

# === Auth ===
# API キー認証（空の場合は認証スキップ）
AGENT_API_KEY=your-agent-api-key

# === CORS ===
# 許可するオリジン（カンマ区切り。空の場合は同一オリジンのみ）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# === ネットワーク ===
# VPN 公開時: BIND_HOST=10.0.0.3（WireGuard IP）
# ローカルのみ: BIND_HOST=127.0.0.1（デフォルト）
# BIND_HOST=127.0.0.1
